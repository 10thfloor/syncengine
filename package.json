{
  "name": "syncengine",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cd apps/test && syncengine dev",
    "build": "cd apps/test && syncengine build",
    "start": "cd apps/test && syncengine start",
    "build:client": "pnpm --filter @syncengine/example build",
    "build:wasm": "cd packages/dbsp-engine && wasm-pack build --target bundler --out-dir pkg --scope syncengine && node ../../scripts/sync-wasm.mjs",
    "postinstall": "test -f packages/dbsp-engine/pkg/dbsp_bg.wasm || pnpm build:wasm",
    "test": "pnpm --filter @syncengine/example test",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm --filter @syncengine/example lint"
  },
  "devDependencies": {
    "@syncengine/cli": "workspace:*",
    "typescript": "~5.9.3"
  },
  "packageManager": "pnpm@10.6.4"
}
