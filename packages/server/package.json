{
  "name": "@syncengine/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./workspace": "./src/workspace/workspace.ts",
    "./serve": "./src/serve.ts"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@restatedev/restate-sdk": "^1.4.0",
    "@syncengine/core": "workspace:*",
    "nats": "^2.28.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "vitest": "^1.0.4"
  }
}
