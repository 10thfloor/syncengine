{
  "name": "@syncengine/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./workspace": "./src/workspace/workspace.ts",
    "./serve": "./src/serve.ts",
    "./test": "./src/test/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nats-io/jetstream": "3.3.1",
    "@nats-io/transport-node": "3.3.1",
    "@restatedev/restate-sdk": "1.13.0",
    "@syncengine/core": "workspace:*",
    "@syncengine/gateway-core": "workspace:*",
    "@syncengine/http-core": "workspace:*",
    "@syncengine/observe": "workspace:*",
    "jose": "^6.2.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "vitest": "^1.0.4",
    "zod": "^3.23.0"
  }
}
