{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "allowImportingTsExtensions": false,
    "paths": {
      "@syncengine/core": ["../core/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/__tests__/**"]
}
