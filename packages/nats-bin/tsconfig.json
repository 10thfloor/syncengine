{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "isolatedModules": true,
    "sourceMap": true,
    "incremental": true,
    "declaration": true,
    "noEmit": true,
    "paths": {
      "@syncengine/bin-utils": ["../bin-utils/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/__tests__/**"]
}
