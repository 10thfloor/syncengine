{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "isolatedModules": true,
    "sourceMap": true,
    "incremental": true,
    "jsx": "react-jsx",
    "allowJs": true,
    "declaration": true,
    "noEmit": true,
    "paths": {
      "@syncengine/core": ["../core/src/index.ts"],
      "@syncengine/core/internal": ["../core/src/internal/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/__tests__/**"]
}
