{
  "name": "@syncengine/client",
  "version": "0.1.0",
  "description": "syncengine browser runtime — useStore, useEntity, useTable, useTopic hooks",
  "exports": {
    ".": "./src/index.ts",
    "./worker": "./src/workers/data-worker.js"
  },
  "publish": {
    "include": [
      "src/**/*.ts",
      "src/workers/data-worker.js",
      "README.md",
      "LICENSE",
      "package.json",
      "jsr.json"
    ],
    "exclude": [
      "src/**/__tests__",
      "src/**/*.test.ts",
      "src/**/*.spec.ts"
    ]
  }
}
