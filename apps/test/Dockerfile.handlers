# Handlers image (scale-out path) — runs the full Node bundle so it
# exposes BOTH the Restate H2C endpoint on :9080 AND the /gateway
# WebSocket bridge on :3000 (the edge proxies /gateway here). Static/
# HTML/RPC routes are also served on :3000 but go unused — the edge
# owns browser-facing traffic.

FROM node:22-bookworm-slim
WORKDIR /app

COPY --chown=node:node dist/ ./dist/
USER node

ENV PORT=9080 \
    HTTP_PORT=3000

EXPOSE 9080 3000

# Liveness: make sure the Restate endpoint accepted our registration
# request — the SDK answers /discover with a 200 when it's ready to
# receive invocations.
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
  CMD node -e "fetch('http://localhost:'+process.env.PORT+'/discover').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

CMD ["node", "dist/server/index.mjs"]
